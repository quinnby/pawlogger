@using CarCareTracker.Helper
@inject IConfigHelper config
@inject ITranslationHelper translator
@{
    var userConfig = config.GetUserConfig(User);
    var userLanguage = userConfig.UserLanguage;
}
@model Vehicle
@{
    ViewData["Title"] = !string.IsNullOrWhiteSpace(Model.PetName)
        ? Model.PetName + (!string.IsNullOrWhiteSpace(Model.Species) ? $" ({Model.Species})" : "")
        : $"{Model.Year} {Model.Make} {Model.Model} ({StaticHelper.GetVehicleIdentifier(Model)})";
}
@section Scripts {
    <script src="~/js/vehicle.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/servicerecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/healthrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/vaccinationrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/medicationrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/vetvisitrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/licensingrecord.js?v=@StaticHelper.VersionNumber"></script>
    @* Phase 6 – centralized pet expense tracking *@
    <script src="~/js/petexpenserecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/gasrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/collisionrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/taxrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/reminderrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/upgraderecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/note.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/reports.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/supplyrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/planrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/odometerrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/inspectionrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/js/equipmentrecord.js?v=@StaticHelper.VersionNumber"></script>
    <script src="~/lib/chart-js/chart.umd.js"></script>
    <script src="~/lib/drawdown/drawdown.js"></script>
    <script src="~/lib/qrcode/qrcode.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
}
@section Nav{
    <div class="container-fluid lubelogger-navbar-container frosted hideOnPrint">
        <div class="row mt-2">
            <div class="d-flex lubelogger-navbar">
                <div class="me-2" style="cursor:pointer;" onclick="returnToGarage()">
                    @if(userConfig.ShowVehicleThumbnail) {
                        <img src="@Model.ImageLocation" class="lubelogger-vehicle-logo @(Model.PetStatus == PetStatus.Active ? "" : "sold")" />
                    } else {
                        <img src="@config.GetSmallLogoUrl()" class="lubelogger-logo" />
                    }
                </div>
                <ul class="nav nav-tabs lubelogger-tab flex-grow-1" id="vehicleTab" role="tablist">
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.Dashboard)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.Dashboard)" id="report-tab" data-bs-toggle="tab" data-bs-target="#report-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-file-bar-graph"></i><span class="ms-2">@translator.Translate(userLanguage, "Dashboard")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.PlanRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.PlanRecord)" id="plan-tab" data-bs-toggle="tab" data-bs-target="#plan-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-bar-chart-steps"></i><span class="ms-2">@translator.Translate(userLanguage, "Planner")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.OdometerRecord)" data-pawlog-legacy="odometer">
                        <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.OdometerRecord)" id="odometer-tab" data-bs-toggle="tab" data-bs-target="#odometer-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle distance tracking, not used for pet care"><i class="bi bi-speedometer"></i><span class="ms-2">@translator.Translate(userLanguage, "Odometer") <small>(Legacy)</small></span></button>
                    </li>
                    @* Phase 3: servicerecord-tab is LEGACY/TRANSITIONAL. It is kept for
                       backward compatibility with existing service record data but should not
                       be treated as a first-class pet-health feature going forward.
                       It will be removed once service record data migration is complete. *@
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.ServiceRecord)" data-pawlog-legacy="servicerecord">
                        <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.ServiceRecord)" id="servicerecord-tab" data-bs-toggle="tab" data-bs-target="#servicerecord-tab-pane" type="button" role="tab" aria-selected="true" title="Legacy tab - retained for data compatibility"><i class="bi bi-card-checklist"></i><span class="ms-2">@translator.Translate(userLanguage, "Service Records") <small>(Legacy)</small></span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="healthrecord-tab" data-bs-toggle="tab" data-bs-target="#healthrecord-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-heart-pulse"></i><span class="ms-2">Health Records</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="vaccination-tab" data-bs-toggle="tab" data-bs-target="#vaccination-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-shield-plus"></i><span class="ms-2">Vaccinations</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="medication-tab" data-bs-toggle="tab" data-bs-target="#medication-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-capsule"></i><span class="ms-2">Medications</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="vetvisit-tab" data-bs-toggle="tab" data-bs-target="#vetvisit-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-hospital"></i><span class="ms-2">Vet Visits</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="licensing-tab" data-bs-toggle="tab" data-bs-target="#licensing-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-card-text"></i><span class="ms-2">Licensing</span></button>
                    </li>
                    @* Phase 6 – centralized pet expense tab *@
                    <li class="nav-item" role="presentation">
                        <button class="nav-link resizable-nav-link" id="expense-tab" data-bs-toggle="tab" data-bs-target="#expense-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-receipt"></i><span class="ms-2">Expenses</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.RepairRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.RepairRecord)" id="accident-tab" data-bs-toggle="tab" data-bs-target="#accident-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-exclamation-octagon"></i><span class="ms-2">@translator.Translate(userLanguage, "Repairs")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.UpgradeRecord)" data-pawlog-legacy="upgrades">
                        <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.UpgradeRecord)" id="upgrade-tab" data-bs-toggle="tab" data-bs-target="#upgrade-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle upgrade records, not used for pet care"><i class="bi bi-wrench-adjustable"></i><span class="ms-2">@translator.Translate(userLanguage, "Upgrades") <small>(Legacy)</small></span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.GasRecord)" data-pawlog-legacy="fuel">
                        <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.GasRecord)" id="gas-tab" data-bs-toggle="tab" data-bs-target="#gas-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle fuel records, not used for pet care"><i class="bi bi-fuel-pump"></i><span class="ms-2">@translator.Translate(userLanguage, "Fuel") <small>(Legacy)</small></span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.SupplyRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.SupplyRecord)" id="supply-tab" data-bs-toggle="tab" data-bs-target="#supply-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-shop"></i><span class="ms-2">@translator.Translate(userLanguage, "Supplies")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.TaxRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.TaxRecord)" id="tax-tab" data-bs-toggle="tab" data-bs-target="#tax-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-currency-dollar"></i><span class="ms-2">@translator.Translate(userLanguage, "Taxes")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.NoteRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.NoteRecord)" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-journal-bookmark"></i><span class="ms-2">@translator.Translate(userLanguage, "Notes")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.InspectionRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.InspectionRecord)" id="inspection-tab" data-bs-toggle="tab" data-bs-target="#inspection-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-clipboard-check"></i><span class="ms-2">@translator.Translate(userLanguage, "Inspections")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.EquipmentRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.EquipmentRecord)" id="equipment-tab" data-bs-toggle="tab" data-bs-target="#equipment-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-disc"></i><span class="ms-2">@translator.Translate(userLanguage, "Equipment")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x=>x == ImportMode.ReminderRecord)">
                        <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.ReminderRecord)" id="reminder-tab" data-bs-toggle="tab" data-bs-target="#reminder-tab-pane" type="button" role="tab" aria-selected="false"><div class="reminderBellDiv" style="display:inline-flex;"><i class="reminderBell bi bi-bell"></i></div><span class="ms-2">@translator.Translate(userLanguage, "Reminders")</span></button>
                    </li>
                    <li class="nav-item" role="presentation" style="order: @(userConfig.TabOrder.Count + 1)">
                        <button class="nav-link resizable-nav-link" type="button" role="tab" aria-selected="false" id="search-tab" onclick="showGlobalSearch()"><i class="bi bi-search"></i><span class="ms-2 ">@translator.Translate(userLanguage, "Search")</span></button>
                    </li>
                    <li class="nav-item dropdown nav-item-persist nav-item-more me-5" role="presentation" style="display:none; order: @(userConfig.TabOrder.Count + 2)">
                        <a class="nav-link resizable-nav-link" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false"><i class="bi bi-three-dots"></i></a>
                        <ul class="dropdown-menu">
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.Dashboard)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.Dashboard)" id="report-tab" data-bs-toggle="tab" data-bs-target="#report-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-file-bar-graph"></i><span class="ms-2">@translator.Translate(userLanguage, "Dashboard")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.PlanRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.PlanRecord)" id="plan-tab" data-bs-toggle="tab" data-bs-target="#plan-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-bar-chart-steps"></i><span class="ms-2">@translator.Translate(userLanguage, "Planner")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.OdometerRecord)" data-pawlog-legacy="odometer">
                                <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.OdometerRecord)" id="odometer-tab" data-bs-toggle="tab" data-bs-target="#odometer-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle distance tracking, not used for pet care"><i class="bi bi-speedometer"></i><span class="ms-2">@translator.Translate(userLanguage, "Odometer") <small>(Legacy)</small></span></button>
                            </li>
                            @* Phase 3: servicerecord-tab is LEGACY/TRANSITIONAL (overflow copy). *@
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.ServiceRecord)" data-pawlog-legacy="servicerecord">
                                <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.ServiceRecord)" id="servicerecord-tab" data-bs-toggle="tab" data-bs-target="#servicerecord-tab-pane" type="button" role="tab" aria-selected="true" title="Legacy tab - retained for data compatibility"><i class="bi bi-card-checklist"></i><span class="ms-2">@translator.Translate(userLanguage, "Service Records") <small>(Legacy)</small></span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="healthrecord-tab" data-bs-toggle="tab" data-bs-target="#healthrecord-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-heart-pulse"></i><span class="ms-2">Health Records</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="vaccination-tab" data-bs-toggle="tab" data-bs-target="#vaccination-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-shield-plus"></i><span class="ms-2">Vaccinations</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="medication-tab" data-bs-toggle="tab" data-bs-target="#medication-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-capsule"></i><span class="ms-2">Medications</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="vetvisit-tab" data-bs-toggle="tab" data-bs-target="#vetvisit-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-hospital"></i><span class="ms-2">Vet Visits</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="licensing-tab" data-bs-toggle="tab" data-bs-target="#licensing-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-card-text"></i><span class="ms-2">Licensing</span></button>
                            </li>
                            @* Phase 6 – centralized pet expense tab (overflow copy) *@
                            <li class="nav-item text-truncate" role="presentation">
                                <button class="nav-link resizable-nav-link" id="expense-tab" data-bs-toggle="tab" data-bs-target="#expense-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-receipt"></i><span class="ms-2">Expenses</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.RepairRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.RepairRecord)" id="accident-tab" data-bs-toggle="tab" data-bs-target="#accident-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-exclamation-octagon"></i><span class="ms-2">@translator.Translate(userLanguage, "Repairs")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.UpgradeRecord)" data-pawlog-legacy="upgrades">
                                <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.UpgradeRecord)" id="upgrade-tab" data-bs-toggle="tab" data-bs-target="#upgrade-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle upgrade records, not used for pet care"><i class="bi bi-wrench-adjustable"></i><span class="ms-2">@translator.Translate(userLanguage, "Upgrades") <small>(Legacy)</small></span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.GasRecord)" data-pawlog-legacy="fuel">
                                <button class="nav-link resizable-nav-link text-muted @StaticHelper.DefaultActiveTab(userConfig, ImportMode.GasRecord)" id="gas-tab" data-bs-toggle="tab" data-bs-target="#gas-tab-pane" type="button" role="tab" aria-selected="false" title="Legacy tab - vehicle fuel records, not used for pet care"><i class="bi bi-fuel-pump"></i><span class="ms-2">@translator.Translate(userLanguage, "Fuel") <small>(Legacy)</small></span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.SupplyRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.SupplyRecord)" id="supply-tab" data-bs-toggle="tab" data-bs-target="#supply-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-shop"></i><span class="ms-2">@translator.Translate(userLanguage, "Supplies")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.TaxRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.TaxRecord)" id="tax-tab" data-bs-toggle="tab" data-bs-target="#tax-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-currency-dollar"></i><span class="ms-2">@translator.Translate(userLanguage, "Taxes")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.NoteRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.NoteRecord)" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-journal-bookmark"></i><span class="ms-2">@translator.Translate(userLanguage, "Notes")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.InspectionRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.InspectionRecord)" id="inspection-tab" data-bs-toggle="tab" data-bs-target="#inspection-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-clipboard-check"></i><span class="ms-2">@translator.Translate(userLanguage, "Inspections")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.EquipmentRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.EquipmentRecord)" id="equipment-tab" data-bs-toggle="tab" data-bs-target="#equipment-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-disc"></i><span class="ms-2">@translator.Translate(userLanguage, "Equipment")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @userConfig.TabOrder.FindIndex(x => x == ImportMode.ReminderRecord)">
                                <button class="nav-link resizable-nav-link @StaticHelper.DefaultActiveTab(userConfig, ImportMode.ReminderRecord)" id="reminder-tab" data-bs-toggle="tab" data-bs-target="#reminder-tab-pane" type="button" role="tab" aria-selected="false"><div class="reminderBellDiv" style="display:inline-flex;"><i class="reminderBell bi bi-bell"></i></div><span class="ms-2">@translator.Translate(userLanguage, "Reminders")</span></button>
                            </li>
                            <li class="nav-item text-truncate" role="presentation" style="order: @(userConfig.TabOrder.Count + 1)">
