@using CarCareTracker.Helper
@inject IConfigHelper config
@inject ITranslationHelper translator
@model Vehicle
@{
    var userConfig = config.GetUserConfig(User);
    var userLanguage = userConfig.UserLanguage;
    var isNew = Model.Id == 0;
    if (Model.ImageLocation == "/defaults/noimage.png")
    {
        Model.ImageLocation = "";
    }
}
<div class="modal-header">
    <h5 class="modal-title" id="addVehicleModalLabel">@(isNew ? translator.Translate(userLanguage, "Add New Pet") : translator.Translate(userLanguage, "Edit Pet"))</h5>
    @if (isNew)
    {
        <button type="button" class="btn-close" onclick="hideAddVehicleModal()" aria-label="Close"></button>
    }
    else
    {
        <button type="button" class="btn-close" onclick="hideEditVehicleModal()" aria-label="Close"></button>
    }
</div>
<div class="modal-body" onkeydown="handleEnter(this)">
    <form class="form-inline">
        <div class="form-group">
            <div class="row">
                <!-- Left column: identity fields -->
                <div class="col-12 col-md-6">
                    <label for="inputPetName">@translator.Translate(userLanguage, "Name")</label>
                    <input type="text" id="inputPetName" class="form-control" placeholder="@translator.Translate(userLanguage, "Name")" value="@Model.PetName">

                    <label for="inputSpecies">@translator.Translate(userLanguage, "Species")</label>
                    <input type="text" id="inputSpecies" class="form-control" placeholder="@translator.Translate(userLanguage, "e.g. Dog, Cat, Rabbit")" value="@Model.Species">

                    <label for="inputBreed">@translator.Translate(userLanguage, "Breed")</label>
                    <input type="text" id="inputBreed" class="form-control" placeholder="@translator.Translate(userLanguage, "Breed(optional)")" value="@Model.Breed">

                    <label for="inputColor">@translator.Translate(userLanguage, "Color / Markings")</label>
                    <input type="text" id="inputColor" class="form-control" placeholder="@translator.Translate(userLanguage, "Color / Markings(optional)")" value="@Model.Color">

                    <label for="inputMicrochipNumber">@translator.Translate(userLanguage, "Microchip Number")</label>
                    <input type="text" id="inputMicrochipNumber" class="form-control" placeholder="@translator.Translate(userLanguage, "Microchip Number(optional)")" value="@Model.MicrochipNumber">

                    @await Html.PartialAsync("_ExtraField", Model.ExtraFields)
                </div>
                <!-- Right column: profile fields -->
                <div class="col-12 col-md-6">
                    <label for="inputSex">@translator.Translate(userLanguage, "Sex")</label>
                    <select class="form-select" id="inputSex">
                        <!option value="Unknown" @(Model.PetSex == "Unknown" || string.IsNullOrWhiteSpace(Model.PetSex) ? "selected" : "")>@translator.Translate(userLanguage, "Unknown")</!option>
                        <!option value="Male"    @(Model.PetSex == "Male"    ? "selected" : "")>@translator.Translate(userLanguage, "Male")</!option>
                        <!option value="Female"  @(Model.PetSex == "Female"  ? "selected" : "")>@translator.Translate(userLanguage, "Female")</!option>
                    </select>

                    <div class="form-check form-switch mt-1">
                        <input class="form-check-input" type="checkbox" role="switch" id="inputSpayedNeutered" checked="@Model.IsSpayedNeutered">
                        <label class="form-check-label" for="inputSpayedNeutered">@translator.Translate(userLanguage, "Spayed / Neutered")</label>
                    </div>

                    <label for="inputDateOfBirth" class="mt-1">@translator.Translate(userLanguage, "Date of Birth")</label>
                    <div class="input-group">
                        <input type="text" id="inputDateOfBirth" class="form-control" placeholder="@translator.Translate(userLanguage, "Date of Birth(optional)")" value="@Model.DateOfBirth">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>
                    <div class="form-check form-switch mt-1">
                        <input class="form-check-input" type="checkbox" role="switch" id="inputEstimatedAge" checked="@Model.IsEstimatedAge">
                        <label class="form-check-label" for="inputEstimatedAge">@translator.Translate(userLanguage, "Age is Estimated")</label>
                    </div>

                    <label for="inputCurrentWeight" class="mt-1">@translator.Translate(userLanguage, "Current Weight")</label>
                    <input type="text" id="inputCurrentWeight" class="form-control" placeholder="@translator.Translate(userLanguage, "e.g. 12.5 lbs(optional)")" value="@Model.CurrentWeight">

                    <label for="inputPetStatus" class="mt-1">@translator.Translate(userLanguage, "Status")</label>
                    <select class="form-select" id="inputPetStatus">
                        <!option value="@((int)PetStatus.Active)"   @(Model.PetStatus == PetStatus.Active   ? "selected" : "")>@translator.Translate(userLanguage, "Active")</!option>
                        <!option value="@((int)PetStatus.Archived)" @(Model.PetStatus == PetStatus.Archived ? "selected" : "")>@translator.Translate(userLanguage, "Archived")</!option>
                        <!option value="@((int)PetStatus.Rehomed)"  @(Model.PetStatus == PetStatus.Rehomed  ? "selected" : "")>@translator.Translate(userLanguage, "Rehomed")</!option>
                        <!option value="@((int)PetStatus.Deceased)" @(Model.PetStatus == PetStatus.Deceased ? "selected" : "")>@translator.Translate(userLanguage, "Deceased")</!option>
                    </select>

                    <!-- Optional profile accordion -->
                    <div class="accordion accordion-flush mt-2" id="petProfileAccordion">
                        <div class="accordion-item">
                            <div class="accordion-header">
                                <button class="accordion-button skinny collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseProfileInfo">
                                    @translator.Translate(userLanguage, "Adoption / Profile Info(optional)")
                                </button>
                            </div>
                            <div id="collapseProfileInfo" class="accordion-collapse collapse" data-bs-parent="#petProfileAccordion">
                                <label for="inputAdoptionDate">@translator.Translate(userLanguage, "Adoption Date")</label>
                                <div class="input-group">
                                    <input type="text" id="inputAdoptionDate" class="form-control" placeholder="@translator.Translate(userLanguage, "Adoption Date")" value="@Model.AdoptionDate">
                                    <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                                </div>
                                <label for="inputSource">@translator.Translate(userLanguage, "Source / Breeder / Shelter")</label>
                                <input type="text" id="inputSource" class="form-control" placeholder="@translator.Translate(userLanguage, "Source(optional)")" value="@Model.Source">
                                <label for="inputPrimaryVet">@translator.Translate(userLanguage, "Primary Vet / Clinic")</label>
                                <input type="text" id="inputPrimaryVet" class="form-control" placeholder="@translator.Translate(userLanguage, "Vet name or clinic(optional)")" value="@Model.PrimaryVet">
                                <label for="inputEmergencyContact">@translator.Translate(userLanguage, "Emergency Contact")</label>
                                <input type="text" id="inputEmergencyContact" class="form-control" placeholder="@translator.Translate(userLanguage, "Emergency contact(optional)")" value="@Model.EmergencyContact">
                                <label for="inputLicenseNumber">@translator.Translate(userLanguage, "License / Tag Number")</label>
                                <input type="text" id="inputLicenseNumber" class="form-control" placeholder="@translator.Translate(userLanguage, "License number(optional)")" value="@Model.LicenseNumber">
                            </div>
                        </div>
                    </div>

                    <!-- Dashboard metrics: only TotalCost is pet-relevant in Phase 2 -->
                    <div class="accordion accordion-flush mt-2" id="petMetricAccordion">
                        <div class="accordion-item">
                            <div class="accordion-header">
                                <button class="accordion-button skinny collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMetricInfo">
                                    @translator.Translate(userLanguage, "Dashboard Metrics")
                                </button>
                            </div>
                            <div id="collapseMetricInfo" class="accordion-collapse collapse" data-bs-parent="#petMetricAccordion">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="inputMetricTotalCost" value="@DashboardMetric.TotalCost" checked="@Model.DashboardMetrics.Contains(DashboardMetric.TotalCost)">
                                    <label class="form-check-label" for="inputMetricTotalCost">@translator.Translate(userLanguage, "Total Care Costs")</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <label for="inputTag" class="mt-2">@translator.Translate(userLanguage, "Tags(optional)")</label>
                    <select multiple class="form-select" id="inputTag">
                        @foreach (string tag in Model.Tags)
                        {
                            <!option value="@tag">@tag</!option>
                        }
                    </select>

                    @if (!string.IsNullOrWhiteSpace(Model.ImageLocation))
                    {
                        <label for="inputImage" class="mt-1">@translator.Translate(userLanguage, "Replace picture(optional)")</label>
                        <input onChange="uploadThumbnail(this)" type="file" accept=".png,.jpg,.jpeg" class="form-control-file" id="inputImage">
                    }
                    else
                    {
                        <label for="inputImage" class="mt-1">@translator.Translate(userLanguage, "Upload a picture(optional)")</label>
                        <input onChange="uploadThumbnail(this)" type="file" accept=".png,.jpg,.jpeg" class="form-control-file" id="inputImage">
                    }
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    @if (isNew)
    {
        <button type="button" class="btn btn-secondary" onclick="hideAddVehicleModal()">@translator.Translate(userLanguage, "Cancel")</button>
        <button type="button" onclick="saveVehicle(false)" class="btn btn-primary">@translator.Translate(userLanguage, "Add Pet")</button>
    }
    else
    {
        <button type="button" class="btn btn-danger me-auto" onclick="deleteVehicle(@Model.Id)">@translator.Translate(userLanguage, "Delete Pet")</button>
        <button type="button" class="btn btn-secondary" onclick="hideEditVehicleModal()">@translator.Translate(userLanguage, "Cancel")</button>
        <button type="button" onclick="saveVehicle(true)" class="btn btn-primary">@translator.Translate(userLanguage, "Save Pet")</button>
    }
</div>
<script>
    var uploadedFile = "@Model.ImageLocation";
    var uploadedMap = "@Model.MapLocation";
    function getVehicleModelData() {
        return { id: @Model.Id }
    }
</script>