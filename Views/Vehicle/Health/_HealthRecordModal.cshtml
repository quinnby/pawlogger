@using CarCareTracker.Helper
@inject IConfigHelper config
@inject ITranslationHelper translator
@model HealthRecordInput
@{
    var isNew = Model.Id == 0;
    var userConfig = config.GetUserConfig(User);
    var userLanguage = userConfig.UserLanguage;
}
<div class="modal-header">
    <h5 class="modal-title">@(isNew ? "Add New Health Record" : "Edit Health Record")</h5>
    <button type="button" class="btn-close" onclick="hideAddHealthRecordModal()" aria-label="Close"></button>
</div>
<div class="modal-body" onkeydown="handleEnter(this)">
    <form>
        <div class="form-group">
            <div class="row">
                <!-- LEFT COLUMN -->
                <div class="col-md-6 col-12">
                    <input type="text" id="workAroundInput" style="height:0px; width:0px; display:none;">

                    <label for="healthRecordDate">Date</label>
                    <div class="input-group">
                        <input type="text" id="healthRecordDate" class="form-control" placeholder="Date of health event" value="@Model.Date">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>

                    <label for="healthRecordCategory" class="mt-2">Category</label>
                    <select id="healthRecordCategory" class="form-select">
                        @foreach (HealthRecordCategory category in Enum.GetValues(typeof(HealthRecordCategory)))
                        {
                            string label = category switch
                            {
                                HealthRecordCategory.VetVisit         => "Vet Visit",
                                HealthRecordCategory.Vaccination      => "Vaccination",
                                HealthRecordCategory.Medication       => "Medication",
                                HealthRecordCategory.IllnessSymptom   => "Illness / Symptom",
                                HealthRecordCategory.ProcedureSurgery => "Procedure / Surgery",
                                HealthRecordCategory.Dental           => "Dental",
                                HealthRecordCategory.Grooming         => "Grooming",
                                HealthRecordCategory.WeightCheck      => "Weight Check",
                                HealthRecordCategory.AllergyReaction  => "Allergy / Reaction",
                                HealthRecordCategory.LabResult        => "Lab Result",
                                HealthRecordCategory.Licensing        => "Licensing",
                                HealthRecordCategory.PreventiveCare   => "Preventive Care",
                                HealthRecordCategory.BehavioralNote   => "Behavioral Note",
                                _                                     => "Miscellaneous Care"
                            };
                            <!option value="@((int)category)" @(Model.Category == category ? "selected" : "")>@label</!option>
                        }
                    </select>

                    <label for="healthRecordTitle" class="mt-2">Title</label>
                    <input type="text" id="healthRecordTitle" class="form-control" placeholder="e.g. Annual Wellness Exam" value="@Model.Title">
                    <div id="healthWeightCategoryHint" class="alert alert-warning py-1 px-2 mt-1 mb-0 small" style="display:none;">
                        <i class="bi bi-speedometer2 me-1"></i>
                        Looks like you're logging a weight measurement. Use
                        <a href="#" class="alert-link" onclick="hideAddHealthRecordModal(); showAddWeightCheckModal(); return false;">Log Weight Check</a>
                        to record it as a structured weight entry (tracked in history &amp; charts).
                    </div>

                    <label for="healthRecordDescription" class="mt-2">Details (optional)</label>
                    <input type="text" id="healthRecordDescription" class="form-control" placeholder="Additional clinical details" value="@Model.Description">

                    <label for="healthRecordCost" class="mt-2">Cost (optional)</label>
                    <input type="text" inputmode="decimal" onkeydown="interceptDecimalKeys(event)" onkeyup="fixDecimalInput(this, 2)"
                           id="healthRecordCost" class="form-control" placeholder="0.00" value="@(isNew ? "" : Model.Cost)">

                    <label for="healthRecordProvider" class="mt-2">Provider / Clinic (optional)</label>
                    <input type="text" id="healthRecordProvider" class="form-control" placeholder="Vet, groomer, clinic name" value="@Model.Provider">

                    <label for="healthRecordTag" class="mt-2">Tags (optional)</label>
                    <select multiple class="form-select" id="healthRecordTag">
                        @foreach (string tag in Model.Tags)
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>

                    @await Html.PartialAsync("_ExtraField", Model.ExtraFields)

                    <!-- Phase 7: Weight tracking fields -->
                    <div id="healthWeightFields" @(Model.Category == HealthRecordCategory.WeightCheck ? "" : "style=\"display:none;\"")>
                        <label class="mt-2">Weight Measurement</label>
                        <div class="input-group">
                            <input type="number" step="0.1" min="0" id="healthWeightValue" class="form-control"
                                   placeholder="e.g. 12.5"
                                   value="@(Model.WeightValue > 0 ? Model.WeightValue.ToString("G") : "")">
                            <select id="healthWeightUnit" class="form-select" style="max-width:90px;">
                                @{
                                    var userWeightPref = userConfig.PreferredWeightUnit;
                                    if (string.IsNullOrWhiteSpace(userWeightPref)) { userWeightPref = "lbs"; }
                                    var modelUnit = Model.WeightUnit;
                                    if (string.IsNullOrWhiteSpace(modelUnit)) { modelUnit = userWeightPref; }
                                }
                                <!option value="lbs" @(modelUnit == "lbs" ? "selected" : "")>lbs</!option>
                                <!option value="kg"  @(modelUnit == "kg"  ? "selected" : "")>kg</!option>
                                <!option value="oz"  @(modelUnit == "oz"  ? "selected" : "")>oz</!option>
                                <!option value="g"   @(modelUnit == "g"   ? "selected" : "")>g</!option>
                            </select>
                        </div>
                    </div>

                    <!-- Phase 7: Allergy fields -->
                    <div id="healthAllergyFields" @(Model.Category == HealthRecordCategory.AllergyReaction ? "" : "style=\"display:none;\"")>
                        <label for="healthAllergyType" class="mt-2">Allergy Type</label>
                        <select id="healthAllergyType" class="form-select">
                            <!option value="" @(string.IsNullOrWhiteSpace(Model.AllergyType) ? "selected" : "")>Unknown</!option>
                            <!option value="Food"          @(Model.AllergyType == "Food"          ? "selected" : "")>Food</!option>
                            <!option value="Medication"    @(Model.AllergyType == "Medication"    ? "selected" : "")>Medication</!option>
                            <!option value="Environmental" @(Model.AllergyType == "Environmental" ? "selected" : "")>Environmental</!option>
                            <!option value="Contact"       @(Model.AllergyType == "Contact"       ? "selected" : "")>Contact</!option>
                        </select>

                        <label for="healthTrigger" class="mt-2">Trigger / Allergen (optional)</label>
                        <input type="text" id="healthTrigger" class="form-control"
                               placeholder="e.g. Chicken, Penicillin, Pollen" value="@Model.Trigger">

                        <label for="healthSeverity" class="mt-2">Severity</label>
                        <select id="healthSeverity" class="form-select">
                            <!option value=""                   @(string.IsNullOrWhiteSpace(Model.Severity)          ? "selected" : "")>Unknown</!option>
                            <!option value="Mild"               @(Model.Severity == "Mild"               ? "selected" : "")>Mild</!option>
                            <!option value="Moderate"           @(Model.Severity == "Moderate"           ? "selected" : "")>Moderate</!option>
                            <!option value="Severe"             @(Model.Severity == "Severe"             ? "selected" : "")>Severe</!option>
                            <!option value="Life-threatening"   @(Model.Severity == "Life-threatening"   ? "selected" : "")>Life-threatening</!option>
                        </select>
                    </div>

                    <!-- Phase 7: Preventive care reminder -->
                    <div id="healthPreventiveCareFields" @(Model.Category == HealthRecordCategory.PreventiveCare ? "" : "style=\"display:none;\"")>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="healthReminderEnabled"
                                   @(Model.ReminderEnabled ? "checked" : "")
                                   onchange="toggleHealthReminderDueDate(this)">
                            <label class="form-check-label" for="healthReminderEnabled">
                                Set a Reminder for Next Due Date
                            </label>
                        </div>
                        <div id="healthReminderDueDateRow" @(Model.ReminderEnabled ? "" : "style=\"display:none;\"")>
                            <label for="healthReminderDueDate" class="mt-2">Next Due Date</label>
                            <div class="input-group">
                                <input type="text" id="healthReminderDueDate" class="form-control"
                                       placeholder="Date next treatment is due" value="@Model.ReminderDueDate">
                                <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN -->
                <div class="col-md-6 col-12">
                    <label for="healthRecordStatus" class="mt-2 mt-md-0">Status</label>
                    <select id="healthRecordStatus" class="form-select">
                        <!option value="0" @(Model.Status == HealthRecordStatus.Open ? "selected" : "")>Open</!option>
                        <!option value="1" @(Model.Status == HealthRecordStatus.Completed ? "selected" : "")>Completed</!option>
                        <!option value="2" @(Model.Status == HealthRecordStatus.Informational ? "selected" : "")>Informational</!option>
                    </select>

                    <label for="healthRecordNotes" class="mt-2">Notes (optional)<a class="link-underline link-underline-opacity-0" onclick="showLinks(this)"><i class="bi bi-markdown ms-2"></i></a></label>
                    <textarea id="healthRecordNotes" class="form-control" rows="4">@Model.Notes</textarea>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="healthRecordFollowUpRequired" @(Model.FollowUpRequired ? "checked" : "")
                               onchange="toggleHealthFollowUpDate(this)">
                        <label class="form-check-label" for="healthRecordFollowUpRequired">
                            Follow-up Required
                        </label>
                    </div>

                    <div id="healthFollowUpDateRow" @(Model.FollowUpRequired ? "" : "style=\"display:none;\"")>
                        <label for="healthRecordFollowUpDate" class="mt-2">Follow-up Date</label>
                        <div class="input-group">
                            <input type="text" id="healthRecordFollowUpDate" class="form-control" placeholder="Date of follow-up" value="@Model.FollowUpDate">
                            <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                        </div>
                    </div>

                    <div class="mt-2">
                        @await Html.PartialAsync("_UploadedFiles", Model.Files)
                        @await Html.PartialAsync("_FileUploader", Model.Files.Any())
                    </div>
                    <div id="filesPendingUpload"></div>
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    @if (!isNew)
    {
        <div class="btn-group" style="margin-right:auto;">
            <button type="button" class="btn btn-md mt-1 mb-1 btn-danger" onclick="deleteHealthRecord(@Model.Id)">Delete</button>
        </div>
    }
    <button type="button" class="btn btn-secondary" onclick="hideAddHealthRecordModal()">Cancel</button>
    @if (isNew)
    {
        <button type="button" class="btn btn-primary" onclick="saveHealthRecordToVehicle()">Add Health Record</button>
    }
    else
    {
        <button type="button" class="btn btn-primary" onclick="saveHealthRecordToVehicle(true)">Save Health Record</button>
    }
</div>
<script>
    function getHealthRecordModelData() {
        return { id: @Model.Id, vehicleId: @Model.VehicleId };
    }
    function toggleHealthFollowUpDate(checkbox) {
        if (checkbox.checked) {
            $("#healthFollowUpDateRow").show();
            initDatePicker($('#healthRecordFollowUpDate'));
        } else {
            $("#healthFollowUpDateRow").hide();
        }
    }
    function toggleHealthReminderDueDate(checkbox) {
        if (checkbox.checked) {
            $("#healthReminderDueDateRow").show();
            initDatePicker($('#healthReminderDueDate'));
        } else {
            $("#healthReminderDueDateRow").hide();
        }
    }
    function onHealthCategoryChange(select) {
        var cat = parseInt(select.value);
        // WeightCheck = 7, AllergyReaction = 8, PreventiveCare = 11
        $("#healthWeightFields").toggle(cat === 7);
        $("#healthAllergyFields").toggle(cat === 8);
        $("#healthPreventiveCareFields").toggle(cat === 11);
        // initialize reminder due date picker if just shown and already checked
        if (cat === 11 && $("#healthReminderEnabled").is(":checked")) {
            initDatePicker($('#healthReminderDueDate'));
        }
        // Refresh the weight-category hint whenever category changes.
        updateWeightCategoryHint();
    }
    // Non-blocking hint: shown when title text suggests weight logging
    // but the selected category is not WeightCheck (7).
    // Guides the user toward the dedicated "Log Weight Check" structured path
    // without blocking normal generic health record creation.
    function updateWeightCategoryHint() {
        var title = $("#healthRecordTitle").val() || "";
        var cat   = parseInt($("#healthRecordCategory").val());
        var titleSuggestsWeight = /weight/i.test(title);
        var isWeightCategory    = (cat === 7);
        $("#healthWeightCategoryHint").toggle(titleSuggestsWeight && !isWeightCategory);
    }
    // wire category change on load
    $("#healthRecordCategory").on("change", function() { onHealthCategoryChange(this); });
    // wire title change to hint logic
    $("#healthRecordTitle").on("input", function() { updateWeightCategoryHint(); });
    // run once on load in case modal was pre-populated (e.g. edit mode)
    updateWeightCategoryHint();
</script>
@if (!isNew && userConfig.EnableAutoFillOdometer == false)
{
    // no odometer auto-fill needed for health records
}
