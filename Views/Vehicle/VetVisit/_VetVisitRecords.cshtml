@using CarCareTracker.Helper
@inject IConfigHelper config
@model List<VetVisitRecord>
@{
    var userConfig = config.GetUserConfig(User);
    var recordTags = Model.SelectMany(x => x.Tags).Distinct();
}
<div class="d-flex flex-column vehicleTabPane">
<div class="row">
    <div class="d-flex justify-content-between">
        <div class="d-flex align-items-center flex-wrap gap-2">
            <span class="badge bg-success" data-aggregate-type="count">@($"# of Vet Visits: {Model.Count()}")</span>
            <span class="badge bg-primary" data-aggregate-type="sum">@($"Total: {Model.Sum(x => x.Cost).ToString("C")}")</span>
            @foreach (string recordTag in recordTags)
            {
                <span onclick="filterTable('vetvisit-tab-pane', this)" class="user-select-none rounded-pill badge bg-secondary tagfilter" style="cursor:pointer;">@recordTag</span>
            }
        </div>
        <div class="lubelogger-record-add">
            <div class="btn-group">
                <button onclick="showAddVetVisitRecordModal()" class="btn btn-primary btn-md mt-1 mb-1"><i class="bi bi-hospital me-2"></i>Add Vet Visit</button>
                <button type="button" class="btn btn-md btn-primary btn-md mt-1 mb-1 dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="visually-hidden">Toggle Dropdown</span>
                </button>
                <ul class="dropdown-menu record-dropdown">
                    <li><a class="dropdown-item" href="#" onclick="printTab()">Print</a></li>
                    <li><a class="dropdown-item" href="#" onclick="searchTableRows('vetvisit-tab-pane')">Search</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
<div class="row vehicleDetailTabContainer flex-grow-1">
    <div class="col-12">
        @if (Model.Any())
        {
        <table class="table table-hover">
            <thead class="sticky-top">
                <tr class="d-flex">
                    <th scope="col" class="col-2 flex-grow-1 text-truncate">Date</th>
                    <th scope="col" class="col-3 text-truncate">Reason</th>
                    <th scope="col" class="col-2 text-truncate d-none d-md-table-cell">Clinic</th>
                    <th scope="col" class="col-2 text-truncate d-none d-md-table-cell">Diagnosis</th>
                    <th scope="col" class="col-1 text-truncate d-none d-sm-table-cell">Cost</th>
                    <th scope="col" class="col-1 text-truncate d-none d-lg-table-cell">Follow-Up</th>
                </tr>
            </thead>
            <tbody>
                @foreach (VetVisitRecord record in Model)
                {
                    <tr class="d-flex user-select-none" style="cursor:pointer;"
                        data-rowId="@record.Id"
                        data-tags='@string.Join(" ", record.Tags)'
                        onclick="handleTableRowClick(this, showEditVetVisitRecordModal, @record.Id)">
                        <td class="col-2 flex-grow-1 text-truncate">@record.Date.ToShortDateString()</td>
                        <td class="col-3 text-truncate">
                            @record.ReasonForVisit
                            @if (!string.IsNullOrWhiteSpace(record.Notes))
                            {
                                <i class="bi bi-chat-text ms-1 text-muted" title="Has notes"></i>
                            }
                            @if (record.Files.Any())
                            {
                                <i class="bi bi-paperclip ms-1 text-muted" title="Has attachments"></i>
                            }
                            @if (record.LinkedHealthRecordId > 0)
                            {
                                <i class="bi bi-link-45deg ms-1 text-success" title="Linked to Health Record timeline"></i>
                            }
                        </td>
                        <td class="col-2 text-truncate d-none d-md-table-cell">@record.Clinic</td>
                        <td class="col-2 text-truncate d-none d-md-table-cell">@record.Diagnosis</td>
                        <td class="col-1 text-truncate d-none d-sm-table-cell">@(record.Cost == 0 ? "-" : record.Cost.ToString("C"))</td>
                        <td class="col-1 text-truncate d-none d-lg-table-cell">
                            @if (record.FollowUpNeeded && !string.IsNullOrWhiteSpace(record.FollowUpDate))
                            {
                                <span class="badge bg-warning text-dark">@record.FollowUpDate</span>
                            }
                            else if (record.FollowUpNeeded)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle"></i></span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
        else
        {
            <div class="d-flex justify-content-center align-items-center mt-4">
                <div class="text-center text-muted">
                    <i class="bi bi-hospital display-4"></i>
                    <p class="mt-2">No vet visit records yet. Add the first one!</p>
                    <button onclick="showAddVetVisitRecordModal()" class="btn btn-outline-primary"><i class="bi bi-plus-lg me-2"></i>Add Vet Visit</button>
                </div>
            </div>
        }
    </div>
</div>
</div>

<div class="modal fade" data-bs-focus="false" id="vetVisitRecordModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="vetVisitRecordModalContent">
        </div>
    </div>
</div>
